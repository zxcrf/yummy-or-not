{
  "expo": {
    "name": "Yummy or Not",
    "slug": "yummy-or-not",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yummyornot",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yummyornot.app"
    },
    "android": {
      "package": "com.yummyornot.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#fff6e6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#fff6e6"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Yummy or Not needs access to your photos so you can add pictures of your meals.",
          "cameraPermission": "Yummy or Not needs access to your camera so you can take pictures of your meals."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/web"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee3132e2-1edf-468b-89fd-f0aa0bc7d3b1"
      }
    },
    "owner": "eas-wynston",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ee3132e2-1edf-468b-89fd-f0aa0bc7d3b1"
    }
  }
}
