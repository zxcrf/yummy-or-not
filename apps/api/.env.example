# ── App environment profile ──────────────────────────────────────────────────
# Selects a named defaults profile. Explicit env vars below ALWAYS override it.
#   local       — PHOTO_STORAGE defaults to "local"  (dev)
#   validation  — PHOTO_STORAGE defaults to "blob"   (preview)
#   prod        — PHOTO_STORAGE defaults to "blob"   (production)
APP_ENV=local

# ── Database ──────────────────────────────────────────────────────────────────
# On serverless (Vercel/Neon), use the POOLED connection string — the host
# contains a "-pooler" segment, e.g.
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/yummyornot

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed web origins.
# Leave unset (or empty) to allow all origins in development.
ALLOWED_ORIGIN=https://yourapp.example.com,http://localhost:8081

# ── Photo storage ─────────────────────────────────────────────────────────────
# "local"  — write to public/uploads/ (dev only; breaks on serverless hosts)
# "s3"     — upload to any S3-compatible service (AWS S3, Cloudflare R2, Supabase)
# "blob"   — upload to Vercel Blob
# Unset → resolved from APP_ENV. Set here to override the profile default.
PHOTO_STORAGE=local

# Public base URL used to render bare photo keys at read time (no trailing slash).
# Required for "s3" (and any backend that stores bare keys). For R2 with a public
# bucket this is the bucket's public host, e.g.
#   https://pub-<hash>.r2.dev
# Not used by "blob" (blob persists the full returned URL).
PHOTO_PUBLIC_BASE_URL=https://pub.example.com/yummyornot-photos

# ── S3 / R2 (PHOTO_STORAGE=s3) ────────────────────────────────────────────────
# S3_ENDPOINT is optional — omit for AWS S3, set for R2/Supabase/MinIO.
# Cloudflare R2: region "auto", endpoint https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=https://a2fb6c4e09957c7f8efac7687cdc1dbd.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=yummyornot-photos
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# ── Vercel Blob (PHOTO_STORAGE=blob) ──────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
