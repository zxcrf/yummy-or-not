# Copy to .env and adjust for your local Postgres.
# The `yon` database must exist and be reachable.
DATABASE_URL=postgresql://root@127.0.0.1:5432/yon

# ── Auth (all optional in dev) ───────────────────────────────────────────────
# Phone OTP: when unset, codes are logged to the server console and returned as
# `devCode` so you can test without an SMS gateway. In production set a webhook
# that receives POST {phone, code} and forwards it to your SMS provider
# (Aliyun / Tencent Cloud SMS for China, Twilio for international, …).
# SMS_WEBHOOK_URL=https://your-gateway.example.com/send

# Social logins light up automatically once both id + secret are present.
# Domestic:
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# International:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
