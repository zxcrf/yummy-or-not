# Copy to .env and adjust for your local Postgres.
# The `yon` database must exist and be reachable.
DATABASE_URL=postgresql://root@127.0.0.1:5432/yon

# ── apps/api (server) ─────────────────────────────────────────────────────────
# CORS allowlist for the headless API. Comma-separated web origins that may call
# /api/**. Unset/empty => permissive "*" (dev only). Native clients send no
# Origin and are always allowed. Example:
# ALLOWED_ORIGIN=https://yummy.example.com,http://localhost:8081

# ── apps/mobile (client, baked into the build) ────────────────────────────────
# Absolute base URL the Expo app (native + RN Web) uses to reach the API.
# Empty => same-origin (web served by the API host). Example:
# EXPO_PUBLIC_API_URL=https://api.yummy.example.com
